<UserControl
    x:Class="BlocksFamilyPlugin.Views.MainPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:BlocksFamilyPlugin.Views.Converters"
    xmlns:vm="clr-namespace:BlocksFamilyPlugin.ViewModels"
    xmlns:views="clr-namespace:BlocksFamilyPlugin.Views"
    Background="#FFF5EFEF"
    FontFamily="Segoe UI"
    MinWidth="420">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter       x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter       x:Key="InvertBoolToVis" Invert="True"/>
        <conv:CategorySelectedBrushConverter  x:Key="CatBgConv"/>
        <conv:CategorySelectedWeightConverter x:Key="CatWtConv"/>
        <conv:CategorySelectedForeConverter   x:Key="CatFgConv"/>
        <conv:FamilyIconGeometryConverter     x:Key="FamilyIcon"/>

        <DataTemplate DataType="{x:Type vm:FamilyCardViewModel}">
            <views:FamilyCardView/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header    -->
            <RowDefinition Height="Auto"/>   <!-- Search    -->
            <RowDefinition Height="*"/>      <!-- Body      -->
            <RowDefinition Height="Auto"/>   <!-- Status    -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Padding="18 14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF4A0812" Offset="0"/>
                    <GradientStop Color="#FF6B0F1A" Offset="0.6"/>
                    <GradientStop Color="#FF8B1A2E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Logo circle with icon -->
                    <Border Width="36" Height="36" CornerRadius="10"
                            Background="#22FFFFFF" Margin="0 0 12 0">
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                                <!-- Simple building/blocks icon -->
                                <Path Data="M 3 21 L 21 21 M 5 21 L 5 8 L 12 3 L 19 8 L 19 21 M 9 21 L 9 15 L 15 15 L 15 21 M 9 11 L 9 11 M 15 11 L 15 11"
                                      Stroke="White" StrokeThickness="1.7"
                                      StrokeLineJoin="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Blocks"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Family Library"
                                   FontSize="10"
                                   Foreground="#BFFFFFFF"/>
                    </StackPanel>
                </StackPanel>

                <!-- Favourites toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Favourites"
                               FontSize="11" Foreground="#BFFFFFFF"
                               VerticalAlignment="Center" Margin="0 0 8 0"/>
                    <CheckBox IsChecked="{Binding ShowFavoritesOnly}"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ SEARCH ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Padding="14 10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF6B0F1A" Offset="0"/>
                    <GradientStop Color="#FF5A0C16" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border Background="#22FFFFFF"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search icon (path) -->
                    <Viewbox Grid.Column="0" Width="14" Height="14"
                             Margin="12 0 0 0" VerticalAlignment="Center"
                             Opacity="0.6">
                        <Canvas Width="24" Height="24">
                            <Path Data="M 11 3 A 8 8 0 1 0 11 19 A 8 8 0 0 0 11 3 Z M 21 21 L 16.65 16.65"
                                  Stroke="White" StrokeThickness="2"
                                  StrokeEndLineCap="Round" Fill="Transparent"/>
                        </Canvas>
                    </Viewbox>

                    <Grid Grid.Column="1">
                        <TextBlock Text="Search families, tags, manufacturers…"
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="#80FFFFFF"
                                   Margin="8 0 0 0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" CaretBrush="White"
                                 SelectionBrush="#40FFFFFF"
                                 FontFamily="Segoe UI" FontSize="12"
                                 Padding="8 0" Height="36"
                                 VerticalContentAlignment="Center"/>
                    </Grid>

                    <Button Grid.Column="2"
                            Command="{Binding ClearSearchCommand}"
                            Visibility="{Binding SearchText, Converter={StaticResource BoolToVis}}"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="0 0 10 0">
                        <Border Width="18" Height="18" CornerRadius="9"
                                Background="#40FFFFFF">
                            <TextBlock Text="✕" FontSize="8" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- ══ BODY — sidebar + cards ════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" MinWidth="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── SIDEBAR ─────────────────────────────────────────────────── -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF5A0C16" Offset="0"/>
                        <GradientStop Color="#FF4A0812" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <DockPanel>
                    <!-- Section label -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="CATEGORIES"
                               FontSize="9" FontWeight="Bold"
                               Foreground="#80FFFFFF"
                               Margin="16 16 0 6"/>

                    <!-- Thin white separator -->
                    <Border DockPanel.Dock="Top"
                            Height="1" Background="#15FFFFFF"
                            Margin="12 0 12 8"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Command="{Binding
                                                DataContext.SelectCategoryCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Left"
                                            Cursor="Hand"
                                            Margin="8 1"
                                            Padding="8 9"
                                            FontFamily="Segoe UI"
                                            FontSize="12">

                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource CatBgConv}">
                                                <Binding/>
                                                <Binding Path="DataContext.SelectedCategory"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </Button.Background>

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Vector icon for this category -->
                                                        <Viewbox Grid.Column="0"
                                                                 Width="16" Height="16"
                                                                 HorizontalAlignment="Center">
                                                            <Canvas Width="24" Height="24">
                                                                <Path Data="{Binding Converter={StaticResource FamilyIcon}}"
                                                                      Stroke="White"
                                                                      StrokeThickness="1.8"
                                                                      StrokeLineJoin="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      Fill="Transparent"
                                                                      Opacity="0.85"/>
                                                            </Canvas>
                                                        </Viewbox>

                                                        <ContentPresenter Grid.Column="1"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="#25FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>

                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource CatFgConv}">
                                                <Binding/>
                                                <Binding Path="DataContext.SelectedCategory"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </Button.Foreground>

                                        <Button.FontWeight>
                                            <MultiBinding Converter="{StaticResource CatWtConv}">
                                                <Binding/>
                                                <Binding Path="DataContext.SelectedCategory"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </Button.FontWeight>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right edge shadow for depth -->
            <Border Grid.Column="0"
                    HorizontalAlignment="Right" Width="8"
                    Panel.ZIndex="5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#14000000" Offset="0"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- ── CARDS ────────────────────────────────────────────────────── -->
            <Grid Grid.Column="1" Background="#FFF5EFEF">

                <!-- Loading overlay -->
                <Border Background="#E6F5EFEF" Panel.ZIndex="10"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="60" Height="60" CornerRadius="30"
                                HorizontalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF6B0F1A" Offset="0"/>
                                    <GradientStop Color="#FF9B2335" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Viewbox Width="28" Height="28">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M 3 21 L 21 21 M 5 21 L 5 8 L 12 3 L 19 8 L 19 21 M 9 21 L 9 15 L 15 15 L 15 21"
                                          Stroke="White" StrokeThickness="1.7"
                                          StrokeLineJoin="Round" StrokeEndLineCap="Round"
                                          Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="Loading library…" FontSize="12"
                                   Foreground="#FF6B0F1A"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0 14 0 0"/>
                        <TextBlock Text="Please wait"
                                   FontSize="10" Foreground="#FF9A6060"
                                   HorizontalAlignment="Center"
                                   Margin="0 3 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}"     Value="False"/>
                                        <Condition Binding="{Binding TotalFamilies}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Width="64" Height="64" CornerRadius="32"
                            BorderThickness="2" BorderBrush="#FFDDC8CC"
                            Background="White"
                            HorizontalAlignment="Center">
                        <Viewbox Width="28" Height="28">
                            <Canvas Width="24" Height="24">
                                <Path Data="M 3 7 L 21 7 L 21 19 C 21 20.1 20.1 21 19 21 L 5 21 C 3.9 21 3 20.1 3 19 Z M 3 7 L 3 5 C 3 3.9 3.9 3 5 3 L 19 3 C 20.1 3 21 3.9 21 5 L 21 7 M 8 12 L 16 12 M 8 16 L 13 16"
                                      Stroke="#FFAA8080" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <TextBlock Text="Nothing found"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#FF3A0808"
                               HorizontalAlignment="Center"
                               Margin="0 14 0 4"/>
                    <TextBlock Text="Try adjusting your search or pick a different category."
                               FontSize="11" Foreground="#FF9A6060"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="220"/>
                </StackPanel>

                <!-- Card grid -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsLoading,
                                           Converter={StaticResource InvertBoolToVis}}">
                    <ItemsControl ItemsSource="{Binding FamilyCards}"
                                  Margin="4 4 4 4">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ══ TOAST ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0 0 0 18"
                CornerRadius="10"
                Padding="18 11"
                Panel.ZIndex="20"
                Visibility="{Binding ToastVisible, Converter={StaticResource BoolToVis}}">
            <Border.Effect>
                <DropShadowEffect Color="#30000000" BlurRadius="14"
                                  ShadowDepth="3" Direction="270"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FF1E8449"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ToastIsError}" Value="True">
                            <Setter Property="Background" Value="#FF8B1A2E"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ToastMessage}"
                           Foreground="White" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- ══ STATUS BAR ═════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Padding="16 7">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF4A0812" Offset="0"/>
                    <GradientStop Color="#FF6B0F1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="10" Foreground="#AAFFFFFF"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="6" Height="6" CornerRadius="3"
                            Background="#FFFFA0A8"
                            Margin="0 0 6 0" VerticalAlignment="Center"/>
                    <TextBlock FontSize="10" Foreground="#AAFFFFFF">
                        <Run Text="{Binding TotalFamilies, Mode=OneWay}"/>
                        <Run Text=" families"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
