<UserControl
    x:Class="BlocksFamilyPlugin.Views.FamilyCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:BlocksFamilyPlugin.Views.Converters"
    Width="172" Cursor="Hand">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter     x:Key="BoolToVis"/>
        <conv:FavoriteColorConverter        x:Key="FavColor"/>
        <conv:CategoryGradientConverter     x:Key="CatGradient"/>
        <conv:FamilyIconGeometryConverter   x:Key="FamilyIcon"/>
    </UserControl.Resources>

    <!-- Outer card shell -->
    <Border x:Name="Root" Margin="6">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background"      Value="White"/>
                <Setter Property="CornerRadius"    Value="12"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush"     Value="#FFE8D8DA"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#14000000" BlurRadius="12"
                                          ShadowDepth="3" Direction="270" Opacity="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#30000000" BlurRadius="20"
                                                  ShadowDepth="5" Direction="270" Opacity="1"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="{Binding PlaceCommand}"/>
        </Border.InputBindings>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="128"/>   <!-- Icon hero         -->
                <RowDefinition Height="*"/>     <!-- Name + stats      -->
                <RowDefinition Height="Auto"/>  <!-- Action button     -->
            </Grid.RowDefinitions>

            <!-- ══ HERO — gradient + vector icon ════════════════════════════ -->
            <Border Grid.Row="0"
                    CornerRadius="12 12 0 0"
                    ClipToBounds="True"
                    Background="{Binding Category, Converter={StaticResource CatGradient}}">
                <Grid>

                    <!-- Subtle dot-grid texture overlay -->
                    <Border Opacity="0.06">
                        <Border.Background>
                            <DrawingBrush TileMode="Tile"
                                          Viewport="0 0 12 12"
                                          ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="White">
                                        <GeometryDrawing.Geometry>
                                            <EllipseGeometry RadiusX="1" RadiusY="1"
                                                             Center="6,6"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.Background>
                    </Border>

                    <!-- Real thumbnail when available -->
                    <Image Source="{Binding ThumbnailUrl}"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ThumbnailUrl}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <!-- Vector icon (stroke, white) — shown when no thumbnail -->
                    <Viewbox Width="52" Height="52"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Viewbox.Style>
                            <Style TargetType="Viewbox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ThumbnailUrl}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Viewbox.Style>
                        <Canvas Width="24" Height="24">
                            <Path Data="{Binding Category, Converter={StaticResource FamilyIcon}}"
                                  Stroke="White"
                                  StrokeThickness="1.6"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Opacity="0.92"/>
                        </Canvas>
                    </Viewbox>

                    <!-- Bottom gradient scrim for badge legibility -->
                    <Border VerticalAlignment="Bottom" Height="44">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#50000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Favourite star — top-right -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0 8 9 0" Panel.ZIndex="5"
                            Command="{Binding ToggleFavoriteCommand}"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Bookmark this family">
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="#22000000">
                            <TextBlock Text="★" FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0 1 0 0"
                                       Foreground="{Binding IsFavorite, Converter={StaticResource FavColor}}"/>
                        </Border>
                    </Button>

                    <!-- PRO badge — top-left -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="9 9 0 0"
                            CornerRadius="5" Padding="6 3"
                            Background="{DynamicResource PremiumBrush}"
                            Visibility="{Binding IsPremium, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="PRO" FontSize="8" FontWeight="Bold"
                                   Foreground="#3A0000"/>
                    </Border>

                    <!-- Loading spinner -->
                    <Border CornerRadius="12 12 0 0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <Border.Background>
                            <SolidColorBrush Color="#CC000000"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Loading…" FontSize="10" Foreground="White"
                                       HorizontalAlignment="Center" Margin="0 5 0 0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ══ INFO — white ══════════════════════════════════════════════ -->
            <StackPanel Grid.Row="1" Margin="12 10 12 6">

                <!-- Family name -->
                <TextBlock Text="{Binding Name}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#FF1A0000"
                           TextTrimming="CharacterEllipsis"
                           LineHeight="18"/>

                <!-- Category label -->
                <TextBlock Text="{Binding Category}"
                           FontSize="10"
                           Foreground="#FF9A6060"
                           Margin="0 2 0 8"/>

                <!-- Divider -->
                <Border Height="1" Background="#FFEEE0E0"/>

                <!-- Stats row -->
                <Grid Margin="0 7 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Rating -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="★" FontSize="11"
                                   Foreground="#FFFFC107"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Rating, StringFormat=' {0:F1}'}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#FF1A0000"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Downloads -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Path Data="M 12 2 L 12 14 M 8 10 L 12 14 L 16 10 M 4 20 L 20 20"
                              Stroke="#FF9A6060" StrokeThickness="1.5"
                              StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Width="12" Height="14" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0 0 4 0"/>
                        <TextBlock Text="{Binding DownloadCount, StringFormat={}{0:N0}, Mode=OneWay}"
                                   FontSize="10" Foreground="#FF9A6060"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ══ PLACE BUTTON ══════════════════════════════════════════════ -->
            <Button Grid.Row="2"
                    Command="{Binding PlaceCommand}"
                    Margin="10 0 10 10"
                    Height="34"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF6B0F1A" Offset="0"/>
                                    <GradientStop Color="#FF9B2335" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Place in project"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <!-- Arrow icon -->
                                <Border Grid.Column="1"
                                        Width="28" Height="28"
                                        CornerRadius="6"
                                        Background="#25FFFFFF"
                                        Margin="0 0 3 0">
                                    <Path Data="M 8 12 L 14 12 M 11 9 L 14 12 L 11 15"
                                          Stroke="White" StrokeThickness="1.6"
                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Width="10" Height="10" Stretch="Uniform"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF8B1A2E" Offset="0"/>
                                            <GradientStop Color="#FFB52B42" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</UserControl>
